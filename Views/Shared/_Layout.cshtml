<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Clínica Sistema</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="navbar">
    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
        <span class="brand-icon">✦</span>
        <span class="brand-text">Clínica<em>Pro</em></span>
    </a>
    <ul class="nav-links">
        <li><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li><a asp-controller="Paciente" asp-action="Index">Pacientes</a></li>
        <li><a asp-controller="Medico" asp-action="Index">Médicos</a></li>
        <li><a asp-controller="Agenda" asp-action="Index">Agenda</a></li>
    </ul>
    <a asp-controller="Agenda" asp-action="Agendar" class="btn-primary-nav">+ Agendar</a>
</nav>

<main class="main-content">
    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success">@TempData["Sucesso"]</div>
    }
    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-error">@TempData["Erro"]</div>
    }

    @RenderBody()
</main>

<footer class="footer">
    <p>ClinicaPro &copy; @DateTime.Now.Year &mdash; ASP.NET MVC · Entity Framework Core · SQLite</p>
</footer>

<script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
